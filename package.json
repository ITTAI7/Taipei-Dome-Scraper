    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cheerio": "^1.2.0",
    "cloakbrowser": "^0.3.30",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "iconv-lite": "^0.7.2",
    "localtunnel": "^2.0.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "ngrok": "^5.0.0-beta.2",
    "playwright-core": "^1.60.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tsx": "^4.21.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
